# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/riskauth

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# App
APP_NAME=Risk-Based Authentication Engine
DEBUG=false
ENVIRONMENT=production
RATE_LIMIT_PER_MINUTE=100

# GeoIP (optional - for geolocation scoring)
GEOIP_DB_PATH=
